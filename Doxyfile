# Doxygen config for chess-game-cpp.
# Generates HTML class documentation under docs/api/ from sources in src/.
# Use:  make doc  (or:  doxygen Doxyfile)

PROJECT_NAME           = "Caissa"
PROJECT_BRIEF          = "Text-mode chess in C++ with an optional AI opponent — OOP2 final project"
OUTPUT_DIRECTORY       = docs/api
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English

INPUT                  = src
RECURSIVE              = YES
FILE_PATTERNS          = *.h *.cpp
EXCLUDE_PATTERNS       =

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES

GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_TREEVIEW      = YES
HTML_OUTPUT            = .

QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES

JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES
INLINE_INHERITED_MEMB  = YES
COLLABORATION_GRAPH    = YES
INHERITANCE_GRAPH      = YES
HAVE_DOT               = NO        # set to YES if Graphviz is installed for diagrams

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO

OPTIMIZE_OUTPUT_FOR_C  = NO
TYPEDEF_HIDES_STRUCT   = NO
